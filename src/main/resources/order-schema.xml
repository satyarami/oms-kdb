<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="com.satya.oms.sbe"
                   id="1"
                   version="0"
                   semanticVersion="1.0.0"
                   description="Order message schema for OMS"
                   byteOrder="littleEndian">
    <types>
        <composite name="messageHeader" description="Message identifiers and length of message root">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId"   primitiveType="uint16"/>
            <type name="version"    primitiveType="uint16"/>
        </composite>

        <!-- Required composite for group dimension -->
        <composite name="groupSizeEncoding" description="Repeating group dimensions">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="numInGroup"  primitiveType="uint8"/>
        </composite>

        <enum name="Side" encodingType="uint8">
            <validValue name="BUY"  description="Buy side">0</validValue>
            <validValue name="SELL" description="Sell side">1</validValue>
        </enum>
        <enum name="OrderState" encodingType="uint8">
            <validValue name="NEW"              description="New order">0</validValue>
            <validValue name="FILLED"           description="Fully filled">1</validValue>
            <validValue name="PARTIALLY_FILLED" description="Partially filled">2</validValue>
            <validValue name="REJECTED"         description="Rejected">3</validValue>
        </enum>
    </types>

    <message name="Order" id="1" description="Order event message">
        <field name="orderId"      id="1" type="uint64"/>
        <field name="symbolId"     id="2" type="uint32"/>
        <field name="side"         id="3" type="Side"/>
        <field name="quantity"     id="4" type="uint64"/>
        <field name="price"        id="5" type="uint64"/>
        <field name="state"        id="6" type="OrderState"/>
        <field name="filledQty"    id="7" type="uint64"/>
        <field name="remainingQty" id="8" type="uint64"/>

        <group name="fills" id="9" dimensionType="groupSizeEncoding">
            <field name="fillQty"     id="10" type="uint64"/>
            <field name="fillPrice"   id="11" type="uint64"/>
            <field name="executionId" id="12" type="uint64"/>
        </group>
    </message>
</sbe:messageSchema>